/* Take the two LSBs of the received 16-bit pattern and drive PD6/PD7 */
static void ApplyPattern(uint16_t pattern)
{
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_9, (pattern & (1U << 0)) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_11, (pattern & (1U << 1)) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOF, GPIO_PIN_14, (pattern & (1U << 2)) ? GPIO_PIN_SET : GPIO_PIN_RESET);
    //HAL_GPIO_WritePin(GPIOD, GPIO_PIN_7, (pattern & (1U << 1)) ? GPIO_PIN_SET : GPIO_PIN_RESET);
}

/* SPI Rx complete interrupt callback: runs after one 16-bit frame arrives */
void HAL_SPI_RxCpltCallback(SPI_HandleTypeDef *hspi)
{
    if (hspi->Instance == SPI1)
    {
        uint16_t word    = rx_word;
        uint16_t pattern = word & 0x7FFFU;   /* keep your existing mask behavior */

        ApplyPattern(pattern);

        /* Flag the event for the main loop (keep ISR short) */
        rx_last_word = word;
        rx_count++;                   /* main loop will notice this */
        rx_tick_ms = HAL_GetTick();   /* for LED pulse window */

        /* Briefly assert PD6 now (will be cleared in main after ~50 ms) */
       // HAL_GPIO_WritePin(GPIOE, GPIO_PIN_9, GPIO_PIN_SET);

        /* Re-arm for the next 16-bit frame (DataSize=16, Size=1 frame) */
        HAL_SPI_Receive_IT(&hspi1, (uint8_t *)&rx_word, 1);
    }
}

/* Optional: recover from SPI error */
void HAL_SPI_ErrorCallback(SPI_HandleTypeDef *hspi)
{
    if (hspi->Instance == SPI1)
    {
        /* Re-arm the receiver */
        HAL_SPI_Receive_IT(&hspi1, (uint8_t *)&rx_word, 1);
    }
}
