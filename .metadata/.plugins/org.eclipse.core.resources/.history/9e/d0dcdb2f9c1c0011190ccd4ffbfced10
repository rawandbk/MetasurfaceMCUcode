*/
  current_mode = MODE_IDLE;
  current_test_pattern = 0;

  test_pattern1[0] = 0;
  test_pattern1[1] = 0;
  test_pattern1[2] = 0;

  test_pattern2[0] = 0;
  test_pattern2[1] = 0;
  test_pattern2[2] = 0;

  test_freq_hz = 1;

  HAL_TIM_Base_Stop_IT(&htim2);
  __HAL_TIM_SET_COUNTER(&htim2, 0);

  ApplyPattern48(0, 0, 0);
  SPI_Rearm_Packet();




  //ApplyPattern48(0, 0, 0);
  //SPI_Rearm_Packet();

  /* Local shadow used to detect new RX events without disabling IRQs */


  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

    /* If a full 3-frame group arrived, apply it once */
	  if (rx_packet_ready)
	  {
	      //printf("SPI packet received\r\n");

	      uint16_t pkt[RX_PACKET_WORDS];
	      for (int i = 0; i < BUF_LEN; i++){
	    	  printf("buffe pos %d: %02X     ", i,rx_packet[i]);
	      }





	      __disable_irq();
	      for (int i = 0; i < RX_PACKET_WORDS; i++) //TRY PROCESSING PACKET AFTER ENABLING IRQ AND ALSO REMOVING PRINTS
	      {
	          pkt[i] = ((uint16_t)rx_packet[2*i + 1] << 8) | rx_packet[2*i];
	          //rx_packet[2*i + 1] = '\0';
	          //rx_packet[2*i] = '\0';
	          //printf("packet:%04X\r\n",pkt[i]);
	      }
	      rx_packet_ready = 0;
	      SPI_Rearm_Packet();

	      __enable_irq();



	      printf("RX: %04X %04X %04X %04X %04X %04X %04X %04X %04X\r\n",
	             pkt[0], pkt[1], pkt[2], pkt[3], pkt[4], pkt[5], pkt[6], pkt[7], pkt[8]);
	      for(int i =0; i< RX_PACKET_WORDS; i++){
	    	  printf("word %d: %02X", i, rx_packet[i]);
	      }

	      if (pkt[0] == SYNC_WORD)
	      {
	          if (pkt[1] == CMD_STATIC)
	          {
	              printf("CMD_STATIC accepted\r\n");
	              current_mode = MODE_STATIC;
	              current_test_pattern = 0;
	              HAL_TIM_Base_Stop_IT(&htim2);

	              ApplyPattern48(pkt[2], pkt[3], pkt[4]);
	              rx_packets_ok++;
	          }
	          else if (pkt[1] == CMD_TEST)
	          {
	              printf("CMD_TEST accepted\r\n");

	              test_pattern1[0] = pkt[2];
	              test_pattern1[1] = pkt[3];
	              test_pattern1[2] = pkt[4];

	              test_pattern2[0] = pkt[5];
	              test_pattern2[1] = pkt[6];
	              test_pattern2[2] = pkt[7];

	              test_freq_hz = pkt[8];
	              if (test_freq_hz == 0)
	                  test_freq_hz = 1;

	              current_mode = MODE_TEST;
	              current_test_pattern = 1;

	              HAL_TIM_Base_Stop_IT(&htim2);
	              ApplyPattern48(test_pattern1[0], test_pattern1[1], test_pattern1[2]);
	              SetSwitchingFrequency(test_freq_hz);
	              HAL_TIM_Base_Start_IT(&htim2);

	              rx_packets_ok++;
	          }
	          else
	          {
	              rx_packets_bad++;
	              printf("Bad cmd: %04X\r\n", pkt[1]);
	          }
	      }
	      else
	      {
	          rx_packets_bad++;
	          printf("Bad sync: %04X\r\n", pkt[0]);
	      }

	  }
  }

  /* USER CODE END 3 */
}

